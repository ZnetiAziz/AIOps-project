# AIOps appliance runtime configuration.
# Copy this file to .env before installing on hardware.

# Public dashboard port served by nginx.
DASHBOARD_PORT=8088

# API internal configuration.
PROMETHEUS_URL=http://prometheus:9090
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=mistral
LOKI_URL=http://loki:3100
ALERTMANAGER_URL=http://alertmanager:9093
GRAFANA_URL=http://grafana:3000
ZABBIX_URL=http://zabbix-web:8080
ZABBIX_USER=Admin
ZABBIX_PASSWORD=zabbix
AIOPS_DB_PATH=/data/aiops.db

# Firewall appliance configuration.
# Keep disabled until WAN/LAN interfaces are confirmed with:
#   ip addr
#   ip route
FIREWALL_ENABLE=0
FIREWALL_WAN_IFACE=eth0
FIREWALL_LAN_IFACE=eth1
FIREWALL_LAN_CIDR=192.168.10.0/24

# TCP ports exposed from the LAN to the appliance itself.
# Defaults cover SSH, dashboard, API, Grafana, Zabbix, Prometheus and Alertmanager.
FIREWALL_LAN_TCP_PORTS=22,8088,8000,3001,8080,9090,9093
