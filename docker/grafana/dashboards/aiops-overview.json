{
  "annotations": {
    "list": [{
      "builtIn": 1,
      "datasource": "-- Grafana --",
      "enable": true,
      "hide": true,
      "name": "Annotations & Alerts",
      "type": "dashboard"
    }]
  },
  "editable": true,
  "gnetId": null,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 0},
      "targets": [{
        "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 60},
              {"color": "red", "value": 85}
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "title": "Memory Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 60},
              {"color": "red", "value": 85}
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "targets": [{
        "expr": "(1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"})) * 100",
        "legendFormat": "{{instance}}"
      }],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 60},
              {"color": "red", "value": 85}
            ]
          },
          "unit": "percent"
        }
      }
    },
    {
      "title": "CPU History",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [{
        "expr": "100 - (avg by(instance)(rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
        "legendFormat": "{{instance}}"
      }]
    },
    {
      "title": "Memory History",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [{
        "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
        "legendFormat": "{{instance}}"
      }]
    },
    {
      "title": "AIOps API — Alertes Reçues",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 16},
      "targets": [{
        "expr": "aiops_alertes_total",
        "legendFormat": "{{severity}}"
      }]
    },
    {
      "title": "AIOps API — Anomalies Détectées",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 16},
      "targets": [{
        "expr": "aiops_anomalies_total",
        "legendFormat": "{{methode}}"
      }]
    },
    {
      "title": "AIOps API — Latence LLM",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 16},
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(aiops_llm_latence_seconds_bucket[5m]))",
        "legendFormat": "P95"
      }]
    },
    {
      "title": "AIOps API — TTD",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 16},
      "targets": [{
        "expr": "aiops_ttd_secondes",
        "legendFormat": "seconds"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 10}
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["aiops"],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "title": "AIOps — Infrastructure Overview",
  "uid": "aiops-overview",
  "version": 1
}
